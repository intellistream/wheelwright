#!/usr/bin/env bash
# Pre-commit hook for sage-pypi-publisher
# Runs ruff check + format on staged Python files.

set -eo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "🔍 Running pre-commit checks..."

# Get staged Python files
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' || true)

if [ -n "$STAGED_PY" ]; then
    if command -v ruff &>/dev/null; then
        ruff format $STAGED_PY
        ruff check --fix $STAGED_PY
        # Re-stage auto-fixed files
        echo "$STAGED_PY" | xargs git add 2>/dev/null || true
        echo -e "${GREEN}✅ Lint check passed${NC}"
    else
        echo -e "${YELLOW}⚠️  ruff not found, skipping lint${NC}"
    fi
else
    echo -e "ℹ️  No staged Python files to check"
fi

echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
exit 0
